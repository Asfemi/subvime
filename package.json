{
  "name": "subvima",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "apps/web"
  ],
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.55.1"
  },
  "overrides": {
    "rollup": "npm:@rollup/wasm-node@4.55.1"
  },
  "scripts": {
    "dev": "cd apps/web && npm run dev",
